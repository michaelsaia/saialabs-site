---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import EmailForm from '../components/EmailForm.astro';

interface Props {
  title: string;
  tagline: string;
  description: string;
  features: string[];
  cta: string;
  slug: string;
  status: string;
  accentColor?: string;
  ogImage?: string;
}

const {
  title,
  tagline,
  description,
  features,
  cta,
  slug,
  status,
  accentColor,
  ogImage,
} = Astro.props;

const statusLabels: Record<string, string> = {
  'gauging-interest': 'Gauging Interest',
  'building': 'In Development',
  'launched': 'Live',
};

const statusColors: Record<string, string> = {
  'gauging-interest': 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20',
  'building': 'bg-blue-500/10 text-blue-400 border-blue-500/20',
  'launched': 'bg-green-500/10 text-green-400 border-green-500/20',
};
---

<BaseLayout
  title={`${title} — Saia Labs`}
  description={tagline}
  ogImage={ogImage}
  noindex={true}
>
  <Header minimal />

  <main class="flex-1 pt-16">
    {accentColor && (
      <style set:html={`
        :root {
          --color-accent: ${accentColor};
          --color-accent-hover: ${accentColor}cc;
          --color-accent-glow: ${accentColor}26;
        }
      `} />
    )}

    <!-- Hero -->
    <section class="animated-gradient min-h-[60vh] flex items-center justify-center relative overflow-hidden">
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(var(--color-text-dim) 1px, transparent 1px), linear-gradient(90deg, var(--color-text-dim) 1px, transparent 1px); background-size: 60px 60px;"></div>

      <div class="relative max-w-3xl mx-auto px-6 text-center py-24">
        <div class="mb-6">
          <span class={`inline-block px-3 py-1 rounded-full text-xs font-medium border ${statusColors[status] || statusColors['gauging-interest']}`}>
            {statusLabels[status] || status}
          </span>
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight mb-4">
          {title}
        </h1>
        <p class="text-xl sm:text-2xl text-[var(--color-text-muted)] max-w-2xl mx-auto font-light">
          {tagline}
        </p>
      </div>
    </section>

    <!-- Description -->
    <section class="py-16 px-6">
      <div class="max-w-3xl mx-auto">
        <p class="text-lg text-[var(--color-text-muted)] leading-relaxed text-center">
          {description}
        </p>
      </div>
    </section>

    <!-- Features -->
    {features.length > 0 && (
      <section class="py-16 px-6 border-t border-[var(--color-border)]">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-sm font-semibold tracking-widest uppercase text-[var(--color-accent)] mb-8 text-center">
            What You Get
          </h2>
          <ul class="space-y-4">
            {features.map((feature) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[var(--color-accent)] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-[var(--color-text-muted)]">{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <!-- Extended Content (markdown body) -->
    <slot />

    <!-- CTA -->
    <section class="py-24 px-6 border-t border-[var(--color-border)]">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl font-bold mb-4">Interested?</h2>
        <p class="text-[var(--color-text-muted)] mb-8">
          Drop your email and we'll let you know when this ships.
        </p>
        <div class="flex justify-center">
          <EmailForm source={slug} ctaText={cta} />
        </div>
      </div>
    </section>

    <!-- Back to Saia Labs -->
    <div class="text-center pb-8">
      <a
        href="/"
        class="text-sm text-[var(--color-text-dim)] hover:text-[var(--color-text-muted)] transition-colors"
      >
        A <span class="font-semibold">saia<span class="text-[var(--color-accent)]">labs</span></span> project
      </a>
    </div>
  </main>

  <Footer />
</BaseLayout>
