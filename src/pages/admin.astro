---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Admin — Saia Labs" noindex={true}>
  <main class="flex-1 pt-16 px-6 pb-24">
    <!-- Login View -->
    <div id="login-view" class="min-h-[70vh] flex items-center justify-center">
      <div class="glass-card p-8 w-full max-w-sm text-center">
        <h1 class="text-2xl font-bold mb-2">Admin Dashboard</h1>
        <p class="text-sm text-[var(--color-text-muted)] mb-6">Enter admin key to view subscriber data.</p>
        <form id="login-form" class="space-y-4">
          <input
            id="admin-key"
            type="password"
            placeholder="Admin key"
            autocomplete="off"
            class="w-full px-4 py-3 rounded-lg bg-[rgba(255,255,255,0.05)] border border-[var(--color-border)] text-[var(--color-text)] placeholder-[var(--color-text-dim)] focus:border-[var(--color-accent)] focus:outline-none transition-colors"
          />
          <button
            type="submit"
            class="w-full px-4 py-3 rounded-lg bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white font-medium transition-colors cursor-pointer"
          >
            View Dashboard
          </button>
          <p id="login-error" class="text-[var(--color-error)] text-sm hidden"></p>
        </form>
      </div>
    </div>

    <!-- Dashboard View (hidden until auth) -->
    <div id="dashboard-view" class="max-w-5xl mx-auto hidden">
      <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-bold">Subscriber Dashboard</h1>
        <button
          id="export-csv"
          class="px-4 py-2 rounded-lg bg-[rgba(255,255,255,0.05)] border border-[var(--color-border)] hover:border-[var(--color-border-hover)] text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors cursor-pointer"
        >
          Export CSV
        </button>
      </div>

      <!-- Summary Table -->
      <div class="glass-card overflow-hidden mb-8" style="transform:none;">
        <table class="w-full text-left">
          <thead>
            <tr class="border-b border-[var(--color-border)]">
              <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">Source</th>
              <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] text-right">Signups</th>
            </tr>
          </thead>
          <tbody id="summary-tbody"></tbody>
        </table>
      </div>

      <!-- Per-slug Detail Sections -->
      <div id="details-container" class="space-y-3"></div>
    </div>
  </main>
</BaseLayout>

<script>
  const WORKER_URL = 'https://saialabs-email.michaelsaia97.workers.dev';

  let dashboardData: { totalCount: number; sources: Record<string, { count: number; subscribers: { email: string; timestamp: string; country: string }[] }> } | null = null;
  let adminKey = '';

  const loginView = document.getElementById('login-view')!;
  const dashboardView = document.getElementById('dashboard-view')!;
  const loginForm = document.getElementById('login-form')!;
  const loginError = document.getElementById('login-error')!;
  const adminKeyInput = document.getElementById('admin-key') as HTMLInputElement;
  const summaryTbody = document.getElementById('summary-tbody')!;
  const detailsContainer = document.getElementById('details-container')!;
  const exportBtn = document.getElementById('export-csv')!;

  loginForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    loginError.classList.add('hidden');
    const key = adminKeyInput.value.trim();
    if (!key) return;

    const btn = loginForm.querySelector('button')!;
    btn.textContent = 'Loading...';
    btn.setAttribute('disabled', 'true');

    try {
      const res = await fetch(`${WORKER_URL}/api/subscribers/all?key=${encodeURIComponent(key)}`);
      if (res.status === 401) {
        loginError.textContent = 'Invalid key.';
        loginError.classList.remove('hidden');
        btn.textContent = 'View Dashboard';
        btn.removeAttribute('disabled');
        return;
      }
      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      dashboardData = await res.json();
      adminKey = key;
      renderDashboard();
    } catch (err) {
      loginError.textContent = 'Failed to fetch data. Try again.';
      loginError.classList.remove('hidden');
      btn.textContent = 'View Dashboard';
      btn.removeAttribute('disabled');
    }
  });

  function renderDashboard() {
    if (!dashboardData) return;
    loginView.classList.add('hidden');
    dashboardView.classList.remove('hidden');

    // Sort sources by count descending
    const sorted = Object.entries(dashboardData.sources).sort((a, b) => b[1].count - a[1].count);

    // Summary table
    let tbodyHtml = '';
    for (const [source, data] of sorted) {
      tbodyHtml += `
        <tr class="border-b border-[var(--color-border)] last:border-b-0">
          <td class="px-6 py-3 text-sm font-mono">${escapeHtml(source)}</td>
          <td class="px-6 py-3 text-sm text-right font-semibold">${data.count}</td>
        </tr>`;
    }
    tbodyHtml += `
      <tr class="bg-[rgba(255,255,255,0.03)]">
        <td class="px-6 py-3 text-sm font-semibold">Total</td>
        <td class="px-6 py-3 text-sm text-right font-bold text-[var(--color-accent)]">${dashboardData.totalCount}</td>
      </tr>`;
    summaryTbody.innerHTML = tbodyHtml;

    // Detail sections
    let detailsHtml = '';
    for (const [source, data] of sorted) {
      const subsSorted = [...data.subscribers].sort(
        (a, b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime()
      );
      const rowsHtml = subsSorted
        .map(
          (s) => `
          <tr class="border-b border-[var(--color-border)] last:border-b-0">
            <td class="px-4 py-2 text-sm font-mono">${escapeHtml(s.email)}</td>
            <td class="px-4 py-2 text-sm text-[var(--color-text-muted)]">${formatDate(s.timestamp)}</td>
            <td class="px-4 py-2 text-sm text-[var(--color-text-muted)]">${escapeHtml(s.country || '—')}</td>
          </tr>`
        )
        .join('');

      detailsHtml += `
        <div class="glass-card overflow-hidden" style="transform:none;">
          <button
            class="detail-toggle w-full px-6 py-4 flex items-center justify-between text-left cursor-pointer"
            data-source="${escapeHtml(source)}"
          >
            <span class="font-mono text-sm">${escapeHtml(source)} <span class="text-[var(--color-text-dim)]">(${data.count})</span></span>
            <svg class="toggle-icon w-4 h-4 text-[var(--color-text-dim)] transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="detail-content hidden">
            <table class="w-full text-left">
              <thead>
                <tr class="border-t border-b border-[var(--color-border)]">
                  <th class="px-4 py-2 text-xs font-semibold uppercase tracking-wider text-[var(--color-text-dim)]">Email</th>
                  <th class="px-4 py-2 text-xs font-semibold uppercase tracking-wider text-[var(--color-text-dim)]">Date</th>
                  <th class="px-4 py-2 text-xs font-semibold uppercase tracking-wider text-[var(--color-text-dim)]">Country</th>
                </tr>
              </thead>
              <tbody>${rowsHtml}</tbody>
            </table>
          </div>
        </div>`;
    }
    detailsContainer.innerHTML = detailsHtml;

    // Toggle handlers
    document.querySelectorAll('.detail-toggle').forEach((btn) => {
      btn.addEventListener('click', () => {
        const content = btn.nextElementSibling as HTMLElement;
        const icon = btn.querySelector('.toggle-icon') as HTMLElement;
        content.classList.toggle('hidden');
        icon.style.transform = content.classList.contains('hidden') ? '' : 'rotate(180deg)';
      });
    });
  }

  // CSV export
  exportBtn.addEventListener('click', () => {
    if (!dashboardData) return;
    const rows = ['source,email,timestamp,country'];
    for (const [source, data] of Object.entries(dashboardData.sources)) {
      for (const s of data.subscribers) {
        rows.push(`${csvEscape(source)},${csvEscape(s.email)},${csvEscape(s.timestamp)},${csvEscape(s.country || '')}`);
      }
    }
    const blob = new Blob([rows.join('\n')], { type: 'text/csv' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    const date = new Date().toISOString().slice(0, 10);
    a.href = url;
    a.download = `saialabs-subscribers-${date}.csv`;
    a.click();
    URL.revokeObjectURL(url);
  });

  function csvEscape(val: string): string {
    if (val.includes(',') || val.includes('"') || val.includes('\n')) {
      return `"${val.replace(/"/g, '""')}"`;
    }
    return val;
  }

  function escapeHtml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function formatDate(iso: string): string {
    try {
      return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    } catch {
      return iso;
    }
  }
</script>
