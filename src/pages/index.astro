---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import EmailForm from '../components/EmailForm.astro';
---

<BaseLayout title="Saia Labs — Building software that solves niche problems">
  <Header />

  <main class="flex-1 pt-16">
    <!-- Hero -->
    <section class="animated-gradient min-h-[80vh] flex items-center justify-center relative overflow-hidden">
      <!-- Subtle grid pattern -->
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(var(--color-text-dim) 1px, transparent 1px), linear-gradient(90deg, var(--color-text-dim) 1px, transparent 1px); background-size: 60px 60px;"></div>

      <div class="relative max-w-4xl mx-auto px-6 text-center py-24">
        <h1 class="text-5xl sm:text-6xl md:text-7xl font-bold tracking-tight mb-6">
          saia<span class="gradient-text">labs</span>
        </h1>
        <p class="text-xl sm:text-2xl text-[var(--color-text-muted)] max-w-2xl mx-auto mb-4 font-light">
          Building software that solves niche problems.
        </p>
        <p class="text-base text-[var(--color-text-dim)] max-w-xl mx-auto mb-12">
          We build tools, automations, and services for the problems nobody else is working on yet.
        </p>

        <div class="flex justify-center">
          <EmailForm source="general" ctaText="Stay in the loop" placeholder="your@email.com" />
        </div>
      </div>
    </section>

    <!-- What We Build -->
    <section class="py-24 px-6">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-sm font-semibold tracking-widest uppercase text-[var(--color-accent)] mb-12 text-center">
          What We Build
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="glass-card p-6">
            <div class="w-10 h-10 rounded-lg bg-[var(--color-accent-glow)] flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </div>
            <h3 class="font-semibold mb-2">Software</h3>
            <p class="text-sm text-[var(--color-text-muted)]">
              Full-stack applications and tools that tackle specific, underserved problems.
            </p>
          </div>

          <div class="glass-card p-6">
            <div class="w-10 h-10 rounded-lg bg-[var(--color-accent-glow)] flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
            </div>
            <h3 class="font-semibold mb-2">Automations</h3>
            <p class="text-sm text-[var(--color-text-muted)]">
              Workflows and systems that eliminate repetitive work and scale processes.
            </p>
          </div>

          <div class="glass-card p-6">
            <div class="w-10 h-10 rounded-lg bg-[var(--color-accent-glow)] flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="font-semibold mb-2">Services</h3>
            <p class="text-sm text-[var(--color-text-muted)]">
              APIs, platforms, and managed services that just work out of the box.
            </p>
          </div>

          <div class="glass-card p-6">
            <div class="w-10 h-10 rounded-lg bg-[var(--color-accent-glow)] flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </div>
            <h3 class="font-semibold mb-2">Experiments</h3>
            <p class="text-sm text-[var(--color-text-muted)]">
              Prototypes and proof-of-concepts exploring ideas at the edge of what's possible.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Philosophy -->
    <section class="py-24 px-6 border-t border-[var(--color-border)]">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-sm font-semibold tracking-widest uppercase text-[var(--color-accent)] mb-8">
          Philosophy
        </h2>
        <p class="text-lg text-[var(--color-text-muted)] leading-relaxed mb-6">
          Most interesting problems don't have billion-dollar markets — they have
          <span class="text-[var(--color-text)]">passionate communities</span> waiting for someone to build the right solution.
          We find those problems, validate them quickly, and ship.
        </p>
        <p class="text-lg text-[var(--color-text-muted)] leading-relaxed">
          No pitch decks. No fundraising. Just
          <span class="text-[var(--color-text)]">building and shipping</span>.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
